# ─────────────────────────────────────────────
# Dependencias y build artifacts (no necesarios para deploy estático)
# ─────────────────────────────────────────────
node_modules
dist

# ─────────────────────────────────────────────
# Código fuente NestJS — solo se usa en dev local (npm run start:dev)
# ─────────────────────────────────────────────
src
nest-cli.json
tsconfig.json
postcss.config.js
tailwind.config.js
*.ts
*.tsbuildinfo

# ─────────────────────────────────────────────
# Archivos huérfanos en la raíz del repo (los oficiales viven en public/
# con nombres distintos: glez-logo.svg y horeb-portrait.jpeg, así que
# excluir estos por nombre simple ya no afecta a los servidos).
# ─────────────────────────────────────────────
FotoHoreb.jpeg
Logowhite.svg

# ─────────────────────────────────────────────
# Originales pesados de /Landingpage (5–16 MB cada uno).
# Solo se sirven las versiones optimizadas en /Landingpage/web/.
# ─────────────────────────────────────────────
public/Landingpage/*.jpg
public/Landingpage/*.jpeg
public/Landingpage/*.JPG
public/Landingpage/*.JPEG
public/Landingpage/*.png
public/Landingpage/*.PNG
!public/Landingpage/web/

# ─────────────────────────────────────────────
# Originales pesados de /SofiayJose (2–7 MB cada uno).
# Solo se sirven las versiones optimizadas en /SofiayJose/v2/.
# (renombrado desde /web/ para bustear cache inmutable de Vercel)
# ─────────────────────────────────────────────
public/SofiayJose/*.jpg
public/SofiayJose/*.jpeg
public/SofiayJose/*.JPG
public/SofiayJose/*.JPEG
public/SofiayJose/*.png
public/SofiayJose/*.PNG
!public/SofiayJose/v2/

# ─────────────────────────────────────────────
# Archivos RAW de cámara — los navegadores no pueden mostrarlos
# y rompen el límite de 25MB/archivo de Vercel Hobby
# ─────────────────────────────────────────────
*.RAF
*.raf
*.raw
*.RAW
*.cr2
*.CR2
*.nef
*.NEF
*.arw
*.ARW
*.dng
*.DNG
*.orf
*.ORF

# ─────────────────────────────────────────────
# Duplicados creados por Finder de macOS ("foto 2.jpg" = copia de "foto.jpg")
# ─────────────────────────────────────────────
* 2.jpg
* 2.jpeg
* 2.png
* 2.JPG
* 2.JPEG
* 2.PNG
* 2.webp
* 2.avif
* copy.jpg
* copy.jpeg
* copy.png

# ─────────────────────────────────────────────
# Sistema / editor
# ─────────────────────────────────────────────
.DS_Store
**/.DS_Store
.claude
.vscode
.idea
*.log
npm-debug.log*

# ─────────────────────────────────────────────
# Lockfiles innecesarios para deploy estático
# ─────────────────────────────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
